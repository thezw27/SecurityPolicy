# Copy this file to ".env" and fill in your keys. ".env" is gitignored — never commit real keys.
#   cp .env.example .env      (PowerShell:  Copy-Item .env.example .env)

# Which backend the agent uses: mock | gemini | openrouter | anthropic
POLICY_PROVIDER=gemini

# Optional model override (otherwise a sensible per-provider default is used)
# POLICY_MODEL=gemini-2.0-flash
# POLICY_MODEL=google/gemini-2.0-flash-001     # example for openrouter

# --- API keys (only the one matching POLICY_PROVIDER is needed) ---
GEMINI_API_KEY=
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
